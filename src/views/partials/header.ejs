<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechVault | Premium Hardware</title>
    <style>
        /* Shared Design System Tokens */
        :root {
            --bg-body: #121212;         /* Deep canvas background */
            --bg-surface: #1e1e1e;      /* Component/Card background */
            --bg-control: #2a2a2a;      /* Field / internal texture backgrounds */
            --border-primary: #333333;  /* High-contrast container borders */
            --border-control: #444444;  /* Input/Interactive item borders */
            --text-main: #e0e0e0;       /* Primary text */
            --text-muted: #888888;      /* Secondary micro-copy */
            
            /* Semantic Identity Colors */
            --accent-cyan: #00bcd4;     /* Core operational highlight */
            --accent-orange: #ffb74d;   /* Administrative workspace color */
            --accent-blue: #4a90e2;     /* Default interactive link color */
            --accent-red: #ff5252;      /* Destructive/Logout action highlight */
            
            --font-stack: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        }

        /* Core Document Resets */
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background-color: var(--bg-body);
            color: var(--text-main);
            font-family: var(--font-stack);
            line-height: 1.6;
            -webkit-font-smoothing: antialiased;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        /* Catch-all baseline for standard content links */
        a {
            color: var(--accent-blue);
            text-decoration: none;
        }
        a:hover {
            text-decoration: underline;
        }

        header {
            background-color: var(--bg-surface);
            border-bottom: 1px solid var(--border-primary);
            padding: 20px 40px 0 40px;
        }

        header h1 {
            font-size: 1.4rem;
            font-weight: 700;
            letter-spacing: -0.5px;
            color: #fff;
            margin-bottom: 16px;
        }

        /* Header Navigation Layout */
        .main-navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 20px;
            padding-bottom: 16px;
        }

        .nav-group {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .main-navbar a {
            color: var(--text-muted);
            font-size: 0.9rem;
            font-weight: 500;
            transition: color 0.2s ease;
        }

        .main-navbar a:hover {
            color: #fff;
            text-decoration: none;
        }

        .nav-divider {
            border-left: 1px solid var(--border-control);
            padding-left: 16px;
        }

        /* Universal Main Body Layout Wrapper */
        main {
            flex: 1;
            padding: 40px;
            max-width: 1300px;
            width: 100%;
            margin: 0 auto;
        }

        /* ==========================================================================
           Unified Application Interface Grid Elements
           ========================================================================== */
        .product-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
            gap: 28px;
            margin-top: 24px;
        }

        .product-card {
            background: var(--bg-surface);
            border: 1px solid var(--border-primary);
            padding: 24px;
            border-radius: 12px;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            box-shadow: 0 4px 16px rgba(0, 0, 0, 0.15);
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        .product-card:hover {
            transform: translateY(-4px);
            border-color: var(--border-control);
            box-shadow: 0 8px 24px rgba(0, 0, 0, 0.25);
        }

        /* FIXED: Beautiful, clean title links that override standard browser defaults */
        .product-card a {
            color: #ffffff;
            font-size: 1.15rem;
            font-weight: 600;
            text-decoration: none;
            margin-bottom: 8px;
            display: inline-block;
            transition: color 0.15s ease;
        }

        .product-card a:hover {
            color: var(--accent-cyan);
            text-decoration: none;
        }

        .product-card img {
            width: 100%;
            height: 180px;
            object-fit: cover;
            border-radius: 6px;
            background-color: var(--bg-control);
            margin-bottom: 16px;
        }

        .price {
            font-size: 1.3rem;
            color: var(--accent-cyan);
            font-weight: 700;
            margin-top: 8px;
        }

        /* ==========================================================================
           Global Utility Component Styles
           ========================================================================== */
        /* FIXED: Sleek back-to-catalog button helper */
        .back-link {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            font-size: 0.9rem;
            font-weight: 500;
            text-decoration: none;
            margin-bottom: 24px;
            transition: color 0.15s ease, transform 0.15s ease;
        }

        .back-link:hover {
            color: #ffffff;
            text-decoration: none;
            transform: translateX(-2px); /* Soft push animation to the left */
        }
    </style>
</head>
<body>
    <header>
        <h1>TechVault Hardware</h1>
        <nav class="main-navbar">
            <div class="nav-group">
                <a href="/">Home Catalog</a>
                
                <!-- RESTRICTION RULE: Hide Shopping Cart and My Orders links if the user is operational staff or admin -->
                <% if (!locals.user || (user.role !== 'employee' && user.role !== 'admin')) { %>
                    <a href="/cart" style="margin-left: 4px;">Shopping Cart</a>
                    <a href="/orders" class="nav-divider">My Orders</a>
                <% } %>
                
                <!-- EMPLOYEE DASHBOARD LINK -->
                <% if (locals.user && user.role === 'employee') { %>
                    <a href="/employee/dashboard" class="nav-divider" style="color: var(--accent-cyan);">Employee Dashboard</a>
                <% } %>

                <!-- ADMIN CONFIGURATION ACCESS PATHS -->
                <% if (locals.user && user.role === 'admin') { %>
                    <a href="/admin/dashboard" class="nav-divider" style="color: var(--accent-orange);">Admin Panel</a>
                    <a href="/admin/users" class="nav-divider" style="color: var(--accent-orange);">Manage Users</a>
                    <a href="/admin/products" class="nav-divider" style="color: var(--accent-orange);">Manage Products</a>
                <% } %>
            </div>
            
            <div class="nav-group">
                <!-- SAFE CHECK: Wrap welcome message and logout option -->
                <% if (locals.user) { %>
                    <span style="font-size: 0.9rem;">
                        Welcome, <strong style="color: #fff;"><%= user.name %></strong> 
                        <span style="text-transform: uppercase; font-size: 0.7rem; color: var(--text-muted); background: var(--bg-control); padding: 2px 6px; border-radius: 4px; margin-left: 4px; border: 1px solid var(--border-primary); font-weight: 600;"><%= user.role %></span>
                    </span>
                    <a href="/logout" class="nav-divider" style="color: var(--accent-red);">Logout</a>
                <% } else { %>
                    <a href="/login">Login</a>
                    <a href="/register" style="color: var(--accent-blue);">Register</a>
                <% } %>
            </div>
        </nav>
    </header>
    <main>