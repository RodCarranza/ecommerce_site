<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>TechVault | Premium Hardware</title>
    <!-- We will use a clean, modern style framework (Water.css or similar) for instant layout styling -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@exampleuser/water.css@2/out/water.css">
    <style>
        nav { display: flex; gap: 20px; margin-bottom: 30px; padding-bottom: 10px; border-bottom: 1px solid #ccc; }
        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 25px; margin-top: 20px; }
        .product-card { border: 1px solid #444; padding: 20px; border-radius: 8px; display: flex; flex-direction: column; justify-content: space-between; }
        .product-card img { max-width: 100%; height: 180px; object-fit: cover; border-radius: 4px; }
        .price { font-size: 1.25rem; color: #00bcd4; font-weight: bold; }
    </style>
</head>
<body>
    <header>
        <h1>TechVault Hardware</h1>
            <nav style="display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 30px; padding-bottom: 10px; border-bottom: 1px solid #444;">
                <div>
                    <a href="/">Home Catalog</a>
                    <a href="/cart" style="margin-left: 15px;">Shopping Cart</a>
                    <a href="/orders" style="border-left: 1px solid #444; padding-left: 15px;">📦 My Orders</a>
                </div>
                <div>
                    <% if (user) { %>
                        <span style="margin-right: 15px; color: #00bcd4;">Welcome, <strong><%= user.name %></strong></span>
                        <a href="/logout" style="color: #ff5252;">Logout</a>
                    <% } else { %>
                        <a href="/login" style="margin-right: 15px;">Login</a>
                        <a href="/register">Register</a>
                    <% } %>
                </div>
            </nav>
    </header>
    <main>