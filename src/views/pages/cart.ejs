<!-- src/views/pages/cart.ejs -->
<%- include('../partials/header') %>

<h2>Your Secure Shopping Cart</h2>

<% if (cartItems.length === 0) { %>
    <blockquote style="margin: 30px 0; padding: 20px; background: #222; border-left: 4px solid #00bcd4;">
        <p>Your cart is empty. <a href="/" style="color: #00bcd4; text-decoration: underline;">Go back to the hardware catalog</a> to load up!</p>
    </blockquote>
<% } else { %>
    <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
        <thead>
            <tr style="border-bottom: 2px solid #444; text-align: left;">
                <th>Product</th>
                <th>Price</th>
                <th>Quantity</th>
                <th>Total</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <% cartItems.forEach(item => { %>
                <tr style="border-bottom: 1px solid #333;">
                    <td style="padding: 15px 0; display: flex; align-items: center; gap: 15px;">
                        <img src="<%= item.image_url %>" alt="<%= item.name %>" style="width: 60px; height: 60px; object-fit: cover; border-radius: 4px;">
                        <strong><%= item.name %></strong>
                    </td>
                    <td>$<%= parseFloat(item.price).toFixed(2) %></td>
                    <td><%= item.quantity %></td>
                    <td>$<%= (parseFloat(item.price) * item.quantity).toFixed(2) %></td>
                    <td>
                        <form action="/cart/delete" method="POST" style="margin: 0;">
                            <!-- Passes the order_item id to delete properly -->
                            <input type="hidden" name="cartItemId" value="<%= item.cart_item_id %>">
                            <button type="submit" style="background: #e53935; color: white; padding: 5px 10px; font-size: 0.85rem; border: none; border-radius: 4px; cursor: pointer;">Remove</button>
                        </form>
                    </td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div style="margin-top: 30px; text-align: right; border-top: 2px solid #444; padding-top: 20px;">
        <h3>Subtotal: <span style="color: #00bcd4;">$<%= subtotal.toFixed(2) %></span></h3>
        <button style="font-size: 1.15rem; padding: 10px 30px; margin-top: 10px; background: #00bcd4; color: #111; font-weight: bold; border: none; border-radius: 4px; cursor: pointer;">
            Proceed to Checkout
        </button>
    </div>
<% } %>

<%- include('../partials/footer') %>