<%- include('../partials/header') %>

<div style="max-width: 400px; margin: 40px auto; padding: 20px; border: 1px solid #444; border-radius: 8px;">
    <h2>Create Secure Account</h2>
    
    <% if (error) { %>
        <p style="color: #ff5252; background: #331c1c; padding: 10px; border-radius: 4px;"><%= error %></p>
    <% } %>

    <form action="/register" method="POST">
        <label for="username">Username:</label>
        <input type="text" id="username" name="username" required style="width: 100%; margin-bottom: 15px;">

        <label for="email">Email Address:</label>
        <input type="email" id="email" name="email" required style="width: 100%; margin-bottom: 15px;">

        <label for="password">Password:</label>
        <input type="password" id="password" name="password" required style="width: 100%; margin-bottom: 25px;">

        <button type="submit" style="width: 100%;">Register Secure Account</button>
    </form>
</div>

<%- include('../partials/footer') %>