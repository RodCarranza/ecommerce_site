<%- include('../partials/header') %>

<h2>Available Hardware Inventory</h2>
<p>Browse our live collection synced directly with our remote cluster database.</p>

<div class="product-grid">
    <% if (products.length === 0) { %>
        <p>No products available in the catalog right now.</p>
    <% } else { %>
        <% products.forEach(product => { %>
            <div class="product-card" style="border: 1px solid #444; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width: 100%; height: 200px; object-fit: cover; border-radius: 4px;">
                <h3><a href="/products/<%= product.id %>"><%= product.name %></a></h3>
                <p><%= product.description %></p>
                <div>
                    <p class="price" style="font-size: 1.25rem; font-weight: bold; color: #00bcd4; margin: 10px 0 5px 0;">$<%= parseFloat(product.price).toFixed(2) %></p>
                    <p style="margin-bottom: 15px;"><small>Stock: <%= product.stock_quantity %> units available</small></p>
                    
                    <!-- 🛑 PROCUREMENT CONTROL: Completely hides the button/form for employees -->
                    <% if (!locals.user || user.role !== 'employee') { %>
                        <form action="/cart" method="POST">
                            <!-- Hidden field passing the unique product ID -->
                            <input type="hidden" name="productId" value="<%= product.id %>">
                            
                            <!-- Defaulting to 1 unit quantity -->
                            <input type="hidden" name="quantity" value="1">
                            
                            <button type="submit" style="width: 100%; background: #00bcd4; color: #111; font-weight: bold; padding: 10px; border: none; border-radius: 4px; cursor: pointer;">
                                Add to Cart
                            </button>
                        </form>
                    <% } %>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include('../partials/footer') %>