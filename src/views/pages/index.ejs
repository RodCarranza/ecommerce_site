<%- include('../partials/header') %>

<h2>Available Hardware Inventory</h2>
<p>Browse our live collection synced directly with our remote cluster database.</p>

<div class="product-grid">
    <% if (products.length === 0) { %>
        <p>No products available in the catalog right now.</p>
    <% } else { %>
        <% products.forEach(product => { %>
            <div class="product-card">
                <img src="<%= product.image_url %>" alt="<%= product.name %>">
                <h3><a href="/products/<%= product.id %>"><%= product.name %></a></h3>
                <p><%= product.description %></p>
                <div>
                    <p class="price">$<%= parseFloat(product.price).toFixed(2) %></p>
                    <p><small>Stock: <%= product.stock_quantity %> units available</small></p>
                    <button style="width: 100%;">Add to Cart</button>
                </div>
            </div>
        <% }) %>
    <% } %>
</div>

<%- include('../partials/footer') %>