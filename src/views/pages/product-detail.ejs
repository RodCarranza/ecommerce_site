<%- include('../partials/header') %>

<p><a href="/">&larr; Back to Catalog Workspace</a></p>

<!-- ADMINISTRATIVE INVENTORY CONTROL PANEL (Visible ONLY to Admins) -->
<% if (locals.user && user.role === 'admin') { %>
    <div style="background: #1c252e; border: 1px solid #ffb74d; padding: 20px; border-radius: 8px; margin-bottom: 35px;">
        <h3 style="color: #ffb74d; margin-top: 0;">System Admin: Edit Product Parameters</h3>
        <form action="/products/<%= product.id %>/edit" method="POST" style="display: flex; flex-wrap: wrap; gap: 20px; align-items: flex-end;">
            <div style="flex: 2; min-width: 200px;">
                <label style="display: block; margin-bottom: 5px; font-size: 0.85rem; color: #ccc;">Hardware Line Name:</label>
                <input type="text" name="name" value="<%= product.name %>" required style="width: 100%; background: #2b2b2b; color: #fff; border: 1px solid #444; padding: 8px; box-sizing: border-box;">
            </div>
            <div style="flex: 1; min-width: 100px;">
                <label style="display: block; margin-bottom: 5px; font-size: 0.85rem; color: #ccc;">Price ($):</label>
                <input type="number" name="price" step="0.01" value="<%= parseFloat(product.price).toFixed(2) %>" required style="width: 100%; background: #2b2b2b; color: #fff; border: 1px solid #444; padding: 8px; box-sizing: border-box;">
            </div>
            <div style="flex: 1; min-width: 100px;">
                <label style="display: block; margin-bottom: 5px; font-size: 0.85rem; color: #ccc;">Warehouse Stock:</label>
                <input type="number" name="stock_quantity" value="<%= product.stock_quantity %>" required style="width: 100%; background: #2b2b2b; color: #fff; border: 1px solid #444; padding: 8px; box-sizing: border-box;">
            </div>
            <div style="flex: 1; min-width: 150px;">
                <button type="submit" style="width: 70%; background: #ffb74d; color: #111; font-weight: bold; padding: 9px; border: none; cursor: pointer;">Commit Changes</button>
            </div>
        </form>
    </div>
<% } %>

<div style="display: flex; gap: 40px; margin-top: 30px; align-items: flex-start;">
    
    <!-- Product Image Workspace -->
    <div style="flex: 1;">
        <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; border: 1px solid #444;">
    </div>
    
    <!-- Product Specifications -->
    <div style="flex: 1;">
        <h2><%= product.name %></h2>
        <p class="price" style="font-size: 2rem; margin: 10px 0;">$<%= parseFloat(product.price).toFixed(2) %></p>
        
        <!-- Contextual Admin Edit Button Positioned Right Inline With Content -->
        <blockquote style="margin: 20px 0; padding: 15px; background: #222; border-left: 4px solid #00bcd4; color:white;">
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px;">
                <strong>Description:</strong>
                <% if (locals.user && user.role === 'admin') { %>
                    <button type="button" 
                            class="btn-edit-alt" 
                            data-id="<%= product.id %>" 
                            data-name="<%= product.name %>"
                            data-description="<%= product.description %>" 
                            onclick="triggerEditDescriptionFlow(this)"
                            style="margin-top: 0; padding: 4px 12px; font-size: 0.8rem; background-color: #ffb74d; color:black;">
                        Edit Description
                    </button>
                <% } %>
            </div>
            <div style="color: #ccc; line-height: 1.6; white-space: pre-wrap;"><%= product.description %></div>
        </blockquote>

        <p><strong>Availability:</strong> <%= product.stock_quantity %> units in inventory</p>

        <!-- PROCUREMENT ACCESS CONTROL: Cart only displays for Customers and Anonymous Guests -->
        <% if (!locals.user || (user.role !== 'employee' && user.role !== 'admin')) { %>
            <form action="/cart" method="POST" style="margin-top: 25px;">
                <input type="hidden" name="productId" value="<%= product.id %>">
                <label for="quantity">Quantity:</label>
                <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>" style="width: 80px; margin-bottom: 15px;">
                <button type="submit" style="width: 100%; display: block;">Securely Add to Cart</button>
            </form>
        <% } %>
    </div>
</div>

<!-- ========================================================================= -->
<!--  REVIEWS & FEEDBACK SECTION -->
<!-- ========================================================================= -->
<hr style="border: 0; border-top: 1px solid #333; margin: 50px 0 30px 0;">

<section class="reviews-section">
    <h3 style="color: #ffb74d; margin-bottom: 25px;">Customer Feedback & Reviews</h3>

    <!-- SUBMIT NEW REVIEW FORM -->
    <% if (locals.user && user.role !== 'employee' && user.role !== 'admin') { %>
        <div style="background: #1e1e1e; padding: 20px; border-radius: 8px; border: 1px solid #00bcd4; margin-bottom: 30px;">
            <h4 style="margin-top: 0; color: #00bcd4;">Leave Your Product Feedback</h4>
            <form action="/products/<%= product.id %>/review" method="POST">
                <div style="margin-bottom: 15px;">
                    <label for="rating" style="display: block; margin-bottom: 5px;">Rating:</label>
                    <select id="rating" name="rating" required style="width: 100px; padding: 5px; background: #2b2b2b; color: white; border: 1px solid #444;">
                        <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                        <option value="4">⭐⭐⭐⭐ (4)</option>
                        <option value="3">⭐⭐⭐ (3)</option>
                        <option value="2">⭐⭐ (2)</option>
                        <option value="1">⭐ (1)</option>
                    </select>
                </div>
                <div style="margin-bottom: 15px;">
                    <label for="comment" style="display: block; margin-bottom: 5px;">Your Review:</label>
                    <textarea id="comment" name="comment" rows="3" required placeholder="Write your thoughts about this hardware..." style="width: 100%; padding: 10px; background: #2b2b2b; color: white; border: 1px solid #444; border-radius: 4px; box-sizing: border-box;"></textarea>
                </div>
                <button type="submit" style="background: #00bcd4; color: black; font-weight: bold; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">Submit Review</button>
            </form>
        </div>
    <% } else if (!locals.user) { %>
        <p style="background: #f4f2d0; padding: 12px; border-radius: 4px; font-size: 0.9rem; border-left: 3px solid #ffb74d;">
             <a href="/login" style="color: #1c1b1a; text-decoration: underline;">Log in to your account</a> to leave a product review.
        </p>
    <% } %>

    <% if (reviews.length === 0) { %>
        <blockquote style="margin: 20px 0; padding: 20px; background: #222; border-left: 4px solid #888; border-radius: 4px;">
            <p style="color: #aaa; margin: 0; font-style: italic;">No reviews yet for this product. Be the first to leave one!</p>
        </blockquote>
    <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 20px;">
            <% reviews.forEach(review => { %>
                <div style="background: #1a1a1a; padding: 20px; border-radius: 8px; border: 1px solid #333;">
                    
                    <!-- STATE A: STATIC DISPLAY PANEL -->
                    <div id="review-display-<%= review.id %>">
                        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; border-bottom: 1px dashed #2a2a2a; padding-bottom: 8px;">
                            <div>
                                <strong style="color: #00bcd4;"><%= review.reviewer_name %></strong>
                                <small style="color: #666; margin-left: 10px;">
                                    <%= new Date(review.created_at).toLocaleDateString() %>
                                </small>
                            </div>
                            <div style="color: #ffb74d; font-size: 1.1rem;">
                                <%= "⭐".repeat(review.rating) %>
                            </div>
                        </div>

                        <p style="color: #ccc; margin: 0; line-height: 1.6; font-style: italic;">
                            "<%= review.comment %>"
                        </p>

                        <!-- Actions Bar (Admins, Employees, and Authors can delete; only Authors can edit) -->
                        <% if (locals.user && (user.id === review.user_id || user.role === 'employee' || user.role === 'admin')) { %>
                            <div style="margin-top: 15px; display: flex; justify-content: flex-end; gap: 15px; align-items: center; font-size: 0.85rem;">
                                
                                <% if (user.id === review.user_id) { %>
                                    <button type="button" onclick="showEdit('<%= review.id %>')", style="background: none; border: none; color: #ffb74d; text-decoration: underline; cursor: pointer; font-size: 0.85rem; padding: 0;">
                                        Edit
                                    </button>
                                <% } %>

                                <div id="delete-actions-<%= review.id %>">
                                    <button type="button" onclick="showConfirm('<%= review.id %>')", style="background: none; border: none; color: #ff5252; text-decoration: underline; cursor: pointer; font-size: 0.85rem; padding: 0;">
                                        Delete
                                    </button>
                                </div>

                                <div id="confirm-panel-<%= review.id %>" style="display: none; gap: 10px; align-items: center; background: #2c1616; padding: 6px 12px; border-radius: 4px; border: 1px solid #5c2626;">
                                    <span style="color: #ffb74d; font-weight: bold; margin-right: 5px;">Confirm delete?</span>
                                    <form action="/products/<%= product.id %>/review/<%= review.id %>/delete" method="POST" style="display: inline; margin: 0; padding: 0;">
                                        <button type="submit" style="background: #ff5252; border: none; color: white; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; font-weight: bold;">
                                            Yes, Delete
                                        </button>
                                    </form>
                                    <button type="button" onclick="hideConfirm('<%= review.id %>')", style="background: #444; border: none; color: #ccc; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">
                                        Cancel
                                    </button>
                                </div>
                            </div>
                        <% } %>
                    </div>

                    <!-- STATE B: INLINE EDIT PANEL -->
                    <% if (locals.user && user.id === review.user_id) { %>
                        <div id="review-edit-<%= review.id %>" style="display: none;">
                            <h4 style="margin: 0 0 15px 0; color: #ffb74d;"> Edit Your Feedback</h4>
                            <form action="/products/<%= product.id %>/review/<%= review.id %>/edit" method="POST">
                                <div style="margin-bottom: 12px;">
                                    <label style="display: block; margin-bottom: 4px; font-size: 0.85rem;">Modify Rating:</label>
                                    <select name="rating" required style="background: #2b2b2b; color: white; border: 1px solid #444; padding: 5px; border-radius: 4px;">
                                        <option value="5" <%= review.rating === 5 ? 'selected' : '' %>>⭐⭐⭐⭐⭐ (5)</option>
                                        <option value="4" <%= review.rating === 4 ? 'selected' : '' %>>⭐⭐⭐⭐ (4)</option>
                                        <option value="3" <%= review.rating === 3 ? 'selected' : '' %>>⭐⭐⭐ (3)</option>
                                        <option value="2" <%= review.rating === 2 ? 'selected' : '' %>>⭐⭐ (2)</option>
                                        <option value="1" <%= review.rating === 1 ? 'selected' : '' %>>⭐ (1)</option>
                                    </select>
                                </div>
                                <div style="margin-bottom: 15px;">
                                    <label style="display: block; margin-bottom: 4px; font-size: 0.85rem;">Update Comment:</label>
                                    <textarea name="comment" rows="3" required style="width: 100%; padding: 10px; background: #2b2b2b; color: white; border: 1px solid #444; border-radius: 4px; box-sizing: border-box;"><%= review.comment %></textarea>
                                </div>
                                <div style="display: flex; gap: 10px;">
                                    <button type="submit" style="background: #ffb74d; color: black; font-weight: bold; padding: 6px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem;">Save Changes</button>
                                    <button type="button" onclick="hideEdit('<%= review.id %>')", style="background: #444; color: white; padding: 6px 15px; border: none; border-radius: 4px; cursor: pointer; font-size: 0.85rem;">Cancel</button>
                                </div>
                            </form>
                        </div>
                    <% } %>

                </div>
            <% }) %>
        </div>
    <% } %>
</section>

<script>
    function showConfirm(reviewId) {
        document.getElementById('delete-actions-' + reviewId).style.display = 'none';
        document.getElementById('confirm-panel-' + reviewId).style.display = 'flex';
    }
    function hideConfirm(reviewId) {
        document.getElementById('delete-actions-' + reviewId).style.display = 'block';
        document.getElementById('confirm-panel-' + reviewId).style.display = 'none';
    }
    function showEdit(reviewId) {
        document.getElementById('review-display-' + reviewId).style.display = 'none';
        document.getElementById('review-edit-' + reviewId).style.display = 'block';
    }
    function hideEdit(reviewId) {
        document.getElementById('review-display-' + reviewId).style.display = 'block';
        document.getElementById('review-edit-' + reviewId).style.display = 'none';
    }
</script>

<!-- EDIT ITEMS DESCRIPTION----------------------------------------->
<style>
    .edit-modal-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.75);
        backdrop-filter: blur(4px);
        display: flex;
        justify-content: center;
        align-items: center;
        z-index: 9999;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.25s ease;
    }
    .edit-modal-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }
    .edit-modal-box {
        background-color: #181818;
        border: 1px solid #3a3a3a;
        border-radius: 8px;
        width: 90%;
        max-width: 550px;
        padding: 28px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.6);
        transform: translateY(-20px);
        transition: transform 0.25s ease;
        font-family: sans-serif;
    }
    .edit-modal-overlay.active .edit-modal-box {
        transform: translateY(0);
    }
    .edit-modal-title {
        color: #ffb74d;
        margin-top: 0;
        font-size: 1.35rem;
        font-weight: bold;
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .edit-modal-body {
        margin: 20px 0;
    }
    .edit-textarea {
        width: 100%;
        height: 120px;
        background-color: #111;
        color: #eee;
        border: 1px solid #444;
        border-radius: 4px;
        padding: 10px;
        box-sizing: border-box;
        font-family: sans-serif;
        font-size: 0.95rem;
        resize: vertical;
    }
    .edit-textarea:focus {
        border-color: #ffb74d;
        outline: none;
    }
    .edit-modal-footer {
        display: flex;
        justify-content: flex-end;
        gap: 12px;
        margin-top: 20px;
    }
    .btn-edit-save {
        background-color: #27ae60;
        color: white;
        border: none;
        padding: 8px 18px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-edit-save:hover {
        background-color: #2ecc71;
    }
    .btn-edit-alt {
        background-color: #2980b9;
        color: white;
        border: none;
        padding: 6px 12px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.2s;
        margin-top: 10px;
    }
    .btn-edit-alt:hover {
        background-color: #3498db;
    }
    .btn-modal-cancel {
        background-color: #333;
        color: #eee;
        border: 1px solid #444;
        padding: 8px 18px;
        border-radius: 4px;
        font-weight: bold;
        cursor: pointer;
        transition: background 0.2s;
    }
    .btn-modal-cancel:hover {
        background-color: #444;
        color: #fff;
    }
</style>

<div id="editDescModal" class="edit-modal-overlay" onclick="closeEditDescModal(event)">
    <div class="edit-modal-box" onclick="event.stopPropagation()">
        <div class="edit-modal-title">
            <span>📝</span> Modify Product Description
        </div>
        <form id="editDescForm" method="POST">
            <div class="edit-modal-body">
                <p style="color: #bbb; margin-bottom: 12px; font-size: 0.9rem;">
                    Updating catalog details for: <strong id="editDescProductName" style="color: #fff;"></strong>
                </p>
                <textarea name="description" id="editDescTextarea" class="edit-textarea"></textarea>
            </div>
            <div class="edit-modal-footer">
                <button type="button" class="btn-modal-cancel" onclick="hideEditDescModal()">Cancel</button>
                <button type="submit" class="btn-edit-save">Save Changes</button>
            </div>
        </form>
    </div>
</div>

<script>
    const editModal = document.getElementById('editDescModal');
    const editForm = document.getElementById('editDescForm');
    const editProdName = document.getElementById('editDescProductName');
    const editTextarea = document.getElementById('editDescTextarea');

    function triggerEditDescriptionFlow(element) {
        const productId = element.getAttribute('data-id');
        const productName = element.getAttribute('data-name');
        const productDesc = element.getAttribute('data-description');

        editForm.setAttribute('action', `/admin/products/${productId}/edit-description`);
        editProdName.textContent = productName;
        editTextarea.value = productDesc;

        editModal.classList.add('active');
        editTextarea.focus();
    }

    function hideEditDescModal() {
        editModal.classList.remove('active');
    }

    function closeEditDescModal(event) {
        if (event.target === editModal) {
            hideEditDescModal();
        }
    }

    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && editModal.classList.contains('active')) {
            hideEditDescModal();
        }
    });
</script>

<%- include('../partials/footer') %>