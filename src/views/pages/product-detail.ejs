<%- include('../partials/header') %>

<p><a href="/">&larr; Back to Catalog Workspace</a></p>

<div style="display: flex; gap: 40px; margin-top: 30px; align-items: flex-start;">
    
    <!-- Product Image Workspace -->
    <div style="flex: 1;">
        <img src="<%= product.image_url %>" alt="<%= product.name %>" style="width: 100%; max-height: 400px; object-fit: cover; border-radius: 8px; border: 1px solid #444;">
    </div>
    
    <!-- Product Specifications -->
    <div style="flex: 1;">
        <h2><%= product.name %></h2>
        <p class="price" style="font-size: 2rem; margin: 10px 0;">$<%= parseFloat(product.price).toFixed(2) %></p>
        
        <blockquote style="margin: 20px 0; padding: 15px; background: #222; border-left: 4px solid #00bcd4;">
            <strong>Description:</strong><br>
            <%= product.description %>
        </blockquote>

        <p><strong>Availability:</strong> <%= product.stock_quantity %> units in inventory</p>

        <form action="/cart" method="POST" style="margin-top: 25px;">
            <input type="hidden" name="productId" value="<%= product.id %>">
            <label for="quantity">Quantity:</label>
            <input type="number" id="quantity" name="quantity" value="1" min="1" max="<%= product.stock_quantity %>" style="width: 80px; margin-bottom: 15px;">
            <button type="submit" style="width: 100%; display: block;">Securely Add to Cart</button>
        </form>
    </div>
</div>

<!-- ========================================================================= -->
<!-- 💬 REVIEWS & FEEDBACK SECTION -->
<!-- ========================================================================= -->
<hr style="border: 0; border-top: 1px solid #333; margin: 50px 0 30px 0;">

<section class="reviews-section">
    <h3 style="color: #ffb74d; margin-bottom: 25px;">💬 Customer Feedback & Reviews</h3>

    <!-- 📝 SUBMIT NEW REVIEW FORM (Only visible to logged-in users) -->
    <% if (locals.user) { %>
        <div style="background: #1e1e1e; padding: 20px; border-radius: 8px; border: 1px solid #00bcd4; margin-bottom: 30px;">
            <h4 style="margin-top: 0; color: #00bcd4;">Leave Your Product Feedback</h4>
            <form action="/products/<%= product.id %>/review" method="POST">
                
                <div style="margin-bottom: 15px;">
                    <label for="rating" style="display: block; margin-bottom: 5px;">Rating:</label>
                    <select id="rating" name="rating" required style="width: 100px; padding: 5px; background: #2b2b2b; color: white; border: 1px solid #444;">
                        <option value="5">⭐⭐⭐⭐⭐ (5)</option>
                        <option value="4">⭐⭐⭐⭐ (4)</option>
                        <option value="3">⭐⭐⭐ (3)</option>
                        <option value="2">⭐⭐ (2)</option>
                        <option value="1">⭐ (1)</option>
                    </select>
                </div>

                <div style="margin-bottom: 15px;">
                    <label for="comment" style="display: block; margin-bottom: 5px;">Your Review:</label>
                    <textarea id="comment" name="comment" rows="3" required placeholder="Write your thoughts about this hardware..." style="width: 100%; padding: 10px; background: #2b2b2b; color: white; border: 1px solid #444; border-radius: 4px; box-sizing: border-box;"></textarea>
                </div>

                <button type="submit" style="background: #00bcd4; color: black; font-weight: bold; padding: 10px 20px; border: none; border-radius: 4px; cursor: pointer;">Submit Review</button>
            </form>
        </div>
    <% } else { %>
        <p style="background: #222; padding: 12px; border-radius: 4px; font-size: 0.9rem; border-left: 3px solid #ffb74d;">
            🔑 <a href="/login" style="color: #ffb74d; text-decoration: underline;">Log in to your Secure Portal account</a> to leave a product review.
        </p>
    <% } %>

    <% if (reviews.length === 0) { %>
        <blockquote style="margin: 20px 0; padding: 20px; background: #222; border-left: 4px solid #888; border-radius: 4px;">
            <p style="color: #aaa; margin: 0; font-style: italic;">No reviews yet for this product. Be the first to leave one!</p>
        </blockquote>
    <% } else { %>
        <div style="display: flex; flex-direction: column; gap: 20px;">
            <% reviews.forEach(review => { %>
                <div style="background: #1a1a1a; padding: 20px; border-radius: 8px; border: 1px solid #333;">
                    
                    <!-- Review Header -->
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 12px; border-bottom: 1px dashed #2a2a2a; padding-bottom: 8px;">
                        <div>
                            <strong style="color: #00bcd4;"><%= review.reviewer_name %></strong>
                            <small style="color: #666; margin-left: 10px;">
                                <%= new Date(review.created_at).toLocaleDateString() %>
                            </small>
                        </div>
                        <div style="color: #ffb74d; font-size: 1.1rem;">
                            <%= "⭐".repeat(review.rating) %>
                        </div>
                    </div>

                    <!-- Comment Text -->
                    <p style="color: #ccc; margin: 0; line-height: 1.6; font-style: italic;">
                        "<%= review.comment %>"
                    </p>

                    <!-- 🛠️ PROFESSIONAL INLINE DELETION CONTROL -->
                    <% if (locals.user && (user.id === review.user_id || user.role === 'admin')) { %>
                        <div style="margin-top: 15px; display: flex; justify-content: flex-end; font-size: 0.85rem;">
                            
                            <!-- Initial State: Simple Delete Link -->
                            <div id="delete-actions-<%= review.id %>">
                                <button type="button" onclick="showConfirm('<%= review.id %>')" style="background: none; border: none; color: #ff5252; text-decoration: underline; cursor: pointer; font-size: 0.85rem; padding: 0;">
                                    Delete
                                </button>
                            </div>

                            <!-- Interactive State: Confirmation Panel (Hidden by default) -->
                            <div id="confirm-panel-<%= review.id %>" style="display: none; gap: 10px; align-items: center; background: #2c1616; padding: 6px 12px; border-radius: 4px; border: 1px solid #5c2626;">
                                <span style="color: #ffb74d; font-weight: bold; margin-right: 5px;">Confirm delete?</span>
                                
                                <form action="/products/<%= product.id %>/review/<%= review.id %>/delete" method="POST" style="display: inline; margin: 0; padding: 0;">
                                    <button type="submit" style="background: #ff5252; border: none; color: white; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem; font-weight: bold;">
                                        Yes, Delete
                                    </button>
                                </form>
                                
                                <button type="button" onclick="hideConfirm('<%= review.id %>')" style="background: #444; border: none; color: #ccc; padding: 4px 10px; border-radius: 4px; cursor: pointer; font-size: 0.8rem;">
                                    Cancel
                                </button>
                            </div>

                        </div>
                    <% } %>

                </div>
            <% }) %>
        </div>
    <% } %>
</section>

<!-- 💡 Mini controller script to toggle confirm state dynamically -->
<script>
    function showConfirm(reviewId) {
        document.getElementById('delete-actions-' + reviewId).style.display = 'none';
        document.getElementById('confirm-panel-' + reviewId).style.display = 'flex';
    }

    function hideConfirm(reviewId) {
        document.getElementById('delete-actions-' + reviewId).style.display = 'block';
        document.getElementById('confirm-panel-' + reviewId).style.display = 'none';
    }
</script>